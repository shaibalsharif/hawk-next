# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it contains real secrets.

# ── Firebase Client (public — safe to expose in browser) ──────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Firebase Admin SDK (server-only — KEEP SECRET) ────────────
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Neon PostgreSQL ────────────────────────────────────────────
# Create a free DB at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── UploadThing ────────────────────────────────────────────────
# Create app at https://uploadthing.com → API Keys
UPLOADTHING_TOKEN=your_uploadthing_token

# ── Session cookie signing ─────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=your_64_char_hex_secret

# ── SMTP (invite & reset emails via nodemailer) ────────────────
# Gmail: host=smtp.gmail.com, port=465, user=you@gmail.com
#        pass = 16-char App Password (Google Account → Security → App passwords)
# Any SMTP provider works — just change host/port/user/pass.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="Hawk Creative Studios <you@gmail.com>"

# ── App URL (used for reset-password email links) ──────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
